{
  "name": "international-chinese-platform",
  "version": "1.0.0",
  "private": true,
  "description": "A self-contained full-stack international Chinese-language education platform.",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/computersciencefreshmen/International_Chinese_Platform.git"
  },
  "homepage": "https://github.com/computersciencefreshmen/International_Chinese_Platform#readme",
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names web,api --prefix-colors cyan,magenta \"pnpm dev:web\" \"pnpm dev:api\"",
    "dev:web": "vite",
    "dev:api": "node --watch server/index.js",
    "start": "node server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "db:migrate": "node server/db/migrate.js",
    "db:seed": "node server/db/seed.js",
    "db:reset": "node server/db/reset.js",
    "test": "pnpm test:api",
    "test:api": "node --test \"server/test/*.test.js\"",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write src/ server/ docs/",
    "format:check": "prettier --check src/ server/ docs/",
    "check": "pnpm lint:check && pnpm format:check && pnpm test:api && pnpm build"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "@fastify/cookie": "^11.1.2",
    "@fastify/helmet": "^13.1.0",
    "@fastify/multipart": "^10.1.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/static": "^10.1.0",
    "@fastify/websocket": "^11.3.0",
    "axios": "^1.8.4",
    "better-sqlite3": "^12.11.1",
    "element-plus": "^2.9.5",
    "fastify": "^5.10.0",
    "pinia": "^2.3.1",
    "pinia-plugin-persistedstate": "4.2.0",
    "vue": "^3.5.13",
    "vue-i18n": "11.0.0-rc.1",
    "vue-router": "^4.5.0",
    "ws": "^8.21.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/eslint-config-prettier": "^10.1.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^10.0.3",
    "eslint": "^9.20.1",
    "eslint-plugin-prettier": "^5.2.3",
    "eslint-plugin-vue": "^9.32.0",
    "postcss": "^8.5.2",
    "prettier": "^3.5.1",
    "sass": "^1.85.0",
    "tailwindcss": "~3.0.24",
    "vite": "^6.0.11",
    "vite-plugin-vue-devtools": "^7.7.1",
    "yaml": "^2.4.2"
  }
}
